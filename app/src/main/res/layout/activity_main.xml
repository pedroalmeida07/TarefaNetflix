<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imgCapaAvatar"
        android:scaleType="centerCrop"
        android:layout_width="wrap_content"
        android:layout_height="317dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/capa_avatar"
        tools:layout_editor_absoluteX="100dp" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="43dp"
        android:layout_height="60dp"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@+id/guideLineVertical1"
        app:layout_constraintTop_toTopOf="@+id/guideLine3"
        app:srcCompat="@drawable/logo_netflix" />

    <TextView
        android:id="@+id/txtMinhaLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minha Lista"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/txtFilmes"
        app:layout_constraintEnd_toStartOf="@+id/guideLineVertical2"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtFilmes"
        app:layout_constraintTop_toTopOf="@+id/txtFilmes" />

    <TextView
        android:id="@+id/txtFilmes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filmes"
        app:layout_constraintBottom_toBottomOf="@+id/txtSerie"
        app:layout_constraintEnd_toStartOf="@+id/txtMinhaLista"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtSerie"
        app:layout_constraintTop_toTopOf="@+id/txtSerie"
        android:textColor="@color/white"/>

    <TextView
        android:id="@+id/txtSerie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Séries"
        app:layout_constraintBottom_toBottomOf="@+id/imgLogo"
        app:layout_constraintEnd_toStartOf="@+id/txtFilmes"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/imgLogo"
        app:layout_constraintTop_toTopOf="@+id/imgLogo"
        android:textSize="14sp"
        android:textColor="@color/white"/>

    <ImageView
        android:id="@+id/imgNomeFilme"
        android:layout_width="150dp"
        android:layout_height="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideLine2"
        app:srcCompat="@drawable/texto_avatar" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLine3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.03"
        android:orientation="horizontal" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLine2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.16" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLine1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.28" />

    <TextView
        android:id="@+id/txtAnimacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:padding="2dp"
        android:text="Animação"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/txtFantasia"
        app:layout_constraintEnd_toStartOf="@+id/txtFantasia"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@+id/guideLineVertical1"
        app:layout_constraintTop_toTopOf="@+id/txtFantasia" />

    <TextView
        android:id="@+id/txtFantasia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:padding="2dp"
        android:text="Fantasia"
        android:textColor="@color/white"
        app:layout_constraintEnd_toStartOf="@+id/txtInfantil"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtAnimacao"
        app:layout_constraintTop_toTopOf="@+id/guideLine1" />

    <TextView
        android:id="@+id/txtInfantil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:padding="2dp"
        android:text="Infantil"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/txtFantasia"
        app:layout_constraintEnd_toStartOf="@+id/guideLineVertical2"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtFantasia"
        app:layout_constraintTop_toTopOf="@+id/txtFantasia" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineVertical1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineVertical2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92"/>

    <Button
        android:id="@+id/btnAssistir"
        android:layout_width="122dp"
        android:layout_height="48dp"
        android:layout_margin="20dp"
        android:drawableLeft="@drawable/ic_assistir_certo"
        android:text="Assistir"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/imgCapaAvatar"
        app:layout_constraintEnd_toStartOf="@+id/btnDetalhes"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btnMinhaLista"
        app:layout_constraintTop_toBottomOf="@id/txtFantasia" />

    <Button
        android:id="@+id/btnMinhaLista"
        android:layout_width="116dp"
        android:layout_height="62dp"
        android:backgroundTint="@android:color/transparent"
        android:text="MINHA LISTA"
        android:textSize="8sp"
        app:icon="@drawable/ic_mais"
        app:iconGravity="top"
        app:iconSize="15dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnAssistir"
        app:layout_constraintEnd_toStartOf="@+id/btnAssistir"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@id/guideLineVertical1"
        app:layout_constraintTop_toTopOf="@+id/btnAssistir" />

    <Button
        android:id="@+id/btnDetalhes"
        android:layout_width="116dp"
        android:layout_height="62dp"
        android:backgroundTint="@android:color/transparent"
        android:text="DETALHES"
        android:textSize="8sp"
        app:icon="@drawable/ic_info"
        app:iconGravity="top"
        app:iconSize="15dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnAssistir"
        app:layout_constraintEnd_toEndOf="@id/guideLineVertical2"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btnAssistir"
        app:layout_constraintTop_toTopOf="@+id/btnAssistir" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalMeio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5"/>

    <TextView
        android:id="@+id/txtLancamento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lançamento"
        android:layout_marginTop="50dp"
        android:textColor="@color/white"
        app:layout_constraintStart_toEndOf="@id/guideLineVertical1"
        app:layout_constraintTop_toBottomOf="@+id/btnAssistir" />

    <ImageView
        android:id="@+id/imgKnives"
        android:layout_width="85dp"
        android:layout_height="56dp"
        app:layout_constraintEnd_toStartOf="@+id/imgDuna"
        app:layout_constraintHorizontal_bias="0.5"
        android:layout_marginTop="5dp"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@id/guideLineVertical1"
        app:layout_constraintTop_toBottomOf="@id/txtLancamento"
        app:srcCompat="@drawable/capa_knives" />

    <ImageView
        android:id="@+id/imgDuna"
        android:layout_width="85dp"
        android:layout_height="56dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgKnives"
        app:layout_constraintEnd_toStartOf="@+id/imgPrenda"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/imgKnives"
        app:layout_constraintTop_toTopOf="@+id/imgKnives"
        app:srcCompat="@drawable/capa_duna" />

    <ImageView
        android:id="@+id/imgPrenda"
        android:layout_width="85dp"
        android:layout_height="56dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgDuna"
        app:layout_constraintEnd_toStartOf="@id/guideLineVertical2"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/imgDuna"
        app:layout_constraintTop_toTopOf="@+id/imgDuna"
        app:srcCompat="@drawable/capa_prenda" />

    <TextView
        android:id="@+id/txtNome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pedro de Souza Almeida"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideLineVertical2"
        app:layout_constraintStart_toStartOf="@+id/guideLineVertical1"
        app:layout_constraintTop_toBottomOf="@+id/imgDuna" />


</androidx.constraintlayout.widget.ConstraintLayout>